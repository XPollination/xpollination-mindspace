{
  "name": "xpollination-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for XPollination content pipeline - trend monitoring, content generation, fact-checking, and publishing",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/src/db && cp src/db/schema.sql dist/src/db/schema.sql",
    "start": "docker compose up --build",
    "start:native": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "test": "vitest",
    "db:migrate": "tsx src/db/migrate.ts",
    "viz": "node viz/server.js",
    "api": "node dist/api/server.js",
    "api:dev": "tsx watch api/server.ts",
    "api:migrate": "tsx api/db/migrate.ts",
    "start:api": "tsx api/db/migrate.ts && tsx api/server.ts",
    "restart:viz": "node scripts/service-lifecycle.js restart viz",
    "restart:api": "node scripts/service-lifecycle.js restart api",
    "deploy:viz": "node scripts/service-lifecycle.js deploy viz",
    "migrate": "node scripts/service-lifecycle.js migrate",
    "health": "node scripts/service-lifecycle.js health",
    "start:test": "docker compose -f docker-compose.test.yml up -d --build",
    "stop:test": "docker compose -f docker-compose.test.yml down",
    "logs:test": "docker compose -f docker-compose.test.yml logs -f",
    "test:acceptance": "bash scripts/acceptance-test.sh",
    "test:acceptance:beta": "bash scripts/acceptance-test.sh http://127.0.0.1:4201 http://127.0.0.1:3101",
    "test:acceptance:prod": "bash scripts/acceptance-test.sh http://10.33.33.1:4200 http://10.33.33.1:3100"
  },
  "keywords": [
    "mcp",
    "content-pipeline",
    "ai-agents",
    "fact-checking",
    "blog-automation"
  ],
  "author": "Thomas Pichler <herr.thomas.pichler@gmail.com>",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@authzed/authzed-node": "^1.2.0",
    "@ipld/dag-json": "^10.2.6",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "express": "^5.2.1",
    "highlight.js": "^11.9.0",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.0",
    "marked": "^17.0.4",
    "multiformats": "^13.4.2",
    "node-pty": "^1.1.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "rss-parser": "^3.13.0",
    "simple-git": "^3.22.0",
    "uuid": "^10.0.0",
    "ws": "^8.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "agent-browser": "^0.21.4",
    "eslint": "^9.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
