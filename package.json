{
  "name": "xpollination-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for XPollination content pipeline - trend monitoring, content generation, fact-checking, and publishing",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc && cp src/db/schema.sql dist/src/db/schema.sql",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "test": "vitest",
    "db:migrate": "tsx src/db/migrate.ts",
    "viz": "node viz/server.js",
    "api": "node dist/api/server.js",
    "api:dev": "tsx watch api/server.ts"
  },
  "keywords": [
    "mcp",
    "content-pipeline",
    "ai-agents",
    "fact-checking",
    "blog-automation"
  ],
  "author": "Thomas Pichler <herr.thomas.pichler@gmail.com>",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "rss-parser": "^3.13.0",
    "simple-git": "^3.22.0",
    "uuid": "^10.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/pino-http": "^5.8.4",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
