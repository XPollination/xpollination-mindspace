# ============================================================================
# XPollination Mindspace — Environment Configuration Template
# ============================================================================
#
# Copy this file to .env.<environment> and fill in the values.
# Every variable listed here is REQUIRED for a working deployment.
# If a variable is missing, the corresponding feature will silently fail.
#
# Usage:
#   cp .env.template .env.beta
#   # Edit .env.beta with environment-specific values
#   # Reference in systemd: EnvironmentFile=/path/to/.env.beta
#
# Environments:
#   .env.prod   — mindspace.xpollination.earth (port 4200, main branch)
#   .env.beta   — beta-mindspace.xpollination.earth (port 4201, develop branch)
#   .env.test   — local testing
#
# ============================================================================

# --- CRITICAL: Auth (login breaks without this) ---
# JWT secret for session cookies. Must match across viz + API servers.
# Without this: login succeeds but session verification fails → redirect loop.
JWT_SECRET=

# --- Server Binding ---
# Viz server port (each environment needs a unique port)
VIZ_PORT=4200
# Bind address (0.0.0.0 = public, 10.33.33.1 = VPN-only)
VIZ_BIND=0.0.0.0

# --- API Server ---
# Port for the Express API backend (shared across environments or per-env)
API_PORT=3100
# CORS origins (comma-separated, empty = none)
CORS_ORIGINS=

# --- Database ---
# SQLite database path (each environment MUST have its own DB)
DATABASE_PATH=./data/xpollination.db

# --- Workspace ---
# Parent directory containing all XPollination repos.
# Viz uses this for project discovery (multi-project support).
# Without this: "Found 0 projects" on the mission map.
XPO_WORKSPACE_PATH=/home/developer/workspaces/github/PichlerThomas

# --- Brain/Memory API ---
BRAIN_API_URL=http://localhost:3200

# --- Environment Marker ---
# Values: production, staging, test
NODE_ENV=staging
