# XPollination MCP Server — TEST environment
# Port offset: +1000 from production
# Separate DB, separate Qdrant collections (test_brain_* prefix)
# VPN-only access: 10.33.33.1:4200

# Database (separate from production)
DATABASE_PATH=./test/data/xpollination-test.db

# Viz server (production 8080 + offset → but test uses 4200 per spec)
VIZ_PORT=4200
VIZ_BIND=10.33.33.1

# Brain API (port offset: 3200 + 1000 = 4200, but test brain not yet deployed)
BRAIN_API_URL=http://localhost:4200

# Qdrant (same server, different collection prefix)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=test_brain_

# Hugo content repository (test — not yet configured)
HUGO_REPO_PATH=./test/hugo
HUGO_CONTENT_PATH=./test/hugo/content/posts

# Git configuration for publishing
GIT_AUTHOR_NAME=XPollination Test Bot
GIT_AUTHOR_EMAIL=test-bot@xpollination.earth

# Server configuration
MCP_SERVER_NAME=xpollination-content-test
MCP_SERVER_VERSION=1.0.0

# Environment marker
NODE_ENV=test
