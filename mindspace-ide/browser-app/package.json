{
  "name": "mindspace-ide-browser",
  "version": "0.1.0",
  "private": true,
  "description": "Mindspace IDE browser application",
  "dependencies": {
    "@theia/core": "~1.69.0",
    "@theia/editor": "~1.69.0",
    "@theia/filesystem": "~1.69.0",
    "@theia/terminal": "~1.69.0",
    "@theia/workspace": "~1.69.0",
    "@theia/navigator": "~1.69.0",
    "@theia/search-in-workspace": "~1.69.0",

    "@theia/preferences": "~1.69.0",
    "@theia/markers": "~1.69.0",
    "@theia/outline-view": "~1.69.0",
    "@theia/monaco": "~1.69.0",
    "@theia/messages": "~1.69.0",
    "@theia/output": "~1.69.0",
    "@theia/process": "~1.69.0",
    "@theia/variable-resolver": "~1.69.0",
    "@theia/scm": "~1.69.0",
    "@mindspace/theia-a2a": "workspace:*",
    "@mindspace/theia-layouts": "workspace:*",
    "@mindspace/theia-branding": "workspace:*"
  },
  "devDependencies": {
    "@theia/cli": "~1.69.0"
  },
  "scripts": {
    "build": "theia build --mode production",
    "start": "theia start --hostname 0.0.0.0 --port 4200",
    "watch": "theia build --watch"
  },
  "theia": {
    "frontend": {
      "config": {
        "applicationName": "Mindspace IDE",
        "preferences": {
          "terminal.integrated.defaultProfile": "bash"
        }
      }
    }
  }
}
