{
  "compilerOptions": {
    "skipLibCheck": true, "target": "ES2020", "module": "commonjs", "moduleResolution": "node",
    "lib": ["ES2020", "DOM"], "outDir": "lib", "rootDir": "src", "strict": true,
    "esModuleInterop": true, "sourceMap": true, "declaration": true,
    "experimentalDecorators": true, "emitDecoratorMetadata": true
  },
  "include": ["src"]
}
