# Mindspace Platform — Environment Configuration
# Copy to .env and fill in values. .env is gitignored.

# === Database ===
DATABASE_PATH=./data/xpollination.db

# === API Server ===
JWT_SECRET=your-secret-here
JWT_EXPIRY=7d
API_PORT=3100

# === Google OAuth (optional — password login works without it) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://hive.xpollination.earth/api/auth/oauth/google/callback
FRONTEND_URL=https://hive.xpollination.earth

# === Viz Server ===
VIZ_PORT=4200
VIZ_BIND=0.0.0.0

# === Brain API ===
BRAIN_API_URL=https://hive.xpollination.earth
BRAIN_API_KEY=your-brain-api-key

# === Agent Identity ===
AGENT_ROLE=dev
XPO_WORKSPACE_PATH=/home/developer/workspaces/github/PichlerThomas

# === Hugo (MCP content pipeline) ===
HUGO_REPO_PATH=/var/www/xpollination.earth
HUGO_CONTENT_PATH=/var/www/xpollination.earth/content/posts
GIT_AUTHOR_NAME=XPollination Bot
GIT_AUTHOR_EMAIL=bot@xpollination.earth
